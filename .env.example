# Vercel API base URL (empty for same-origin, set for Capacitor/Android)
VITE_API_URL=

# JWT secret for token signing (set in Vercel dashboard)
JWT_SECRET=your-secret-key-change-this

# Vercel KV environment variables (auto-added when KV is linked)
# KV_URL=redis://...
# KV_REST_API_URL=https://...
# KV_REST_API_TOKEN=...
# KV_REST_API_READ_ONLY_TOKEN=...
