# URL base da API (vazio = mesma origem no Vercel; preencher para Android/Capacitor)
# Para build Android: VITE_API_URL=https://www.breyne.app
VITE_API_URL=https://www.breyne.app

# Vercel Blob Storage (criar um store em https://vercel.com/storage/blob)
BLOB_READ_WRITE_TOKEN=

# JWT secret for token signing
JWT_SECRET=your-secret-key-here
